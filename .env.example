# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# OpenAI / AI Integrations (set via Replit Secrets — never put real keys here)
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Qdrant Vector DB
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Server
PORT=3001
NODE_ENV=development

# ── Sprint 4ד: AI Feature Flags (all default off — set true to enable) ────────
# Main switch: set to "true" to enable AI features globally
SYNCO_AI_ENABLED=false

# AI provider: "openai" | "gemini" | "claude" | "mock" (gemini/claude = stubs)
SYNCO_AI_PROVIDER=openai

# Per-feature flags (only active when SYNCO_AI_ENABLED=true)
SYNCO_AI_PARSE_ENABLED=false
SYNCO_AI_TASK_REPORT_ENABLED=false
SYNCO_AI_BREAKDOWN_ENABLED=false
SYNCO_AI_DAY_COMMAND_ENABLED=false
